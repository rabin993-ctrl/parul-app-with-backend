# Copy to the droplet as /etc/caddy/Caddyfile, then: systemctl reload caddy
# Caddy provisions HTTPS automatically (Let's Encrypt) as long as parul.pet's A record
# points at this droplet and is NOT proxied through Cloudflare (grey cloud / DNS-only).

parul.pet {
    root * /var/www/parul
    encode gzip
    try_files {path} /index.html   # SPA fallback for client-side routing
    file_server
}

# optional: redirect www -> apex
www.parul.pet {
    redir https://parul.pet{uri} permanent
}
