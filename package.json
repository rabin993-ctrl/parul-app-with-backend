  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "bash scripts/prepare-web-public-assets.sh && expo export -p web",
    "build:web": "bash scripts/prepare-web-public-assets.sh && expo export -p web",
    "tsc": "tsc --noEmit",
    "supabase:link": "supabase link",
    "db:push": "supabase db push",
    "db:seed-vault": "node scripts/seed-vault-edge.mjs",
    "db:reset": "supabase db reset",
    "db:reset:remote": "supabase db reset --linked --no-seed --yes",
    "db:reset:remote:seed": "supabase db reset --linked --yes",
    "db:diff": "supabase db diff",
    "db:seed": "supabase db reset",
    "clean-slate": "bash scripts/clean-slate.sh",
    "clean-slate:local": "bash scripts/clean-slate-local.sh",
    "clean-slate:seed": "bash scripts/clean-slate-with-seed.sh",
    "clean-slate:storage": "node scripts/empty-storage.mjs",
    "gen:types": "supabase gen types typescript --linked > src/lib/db-types.ts",
    "fn:serve": "supabase functions serve",
    "fn:deploy": "supabase functions deploy",
    "deploy:web": "bash scripts/deploy-web.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
