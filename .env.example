# Copy to .env and fill in. Only EXPO_PUBLIC_* values reach the app bundle.
# Get these from: npx supabase projects api-keys --project-ref <REF>

EXPO_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>

# Optional — set in Wave 7 once Cloudflare CDN is in front of Storage
EXPO_PUBLIC_CDN_URL=

# Optional — error reporting
EXPO_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# SECRETS BELOW: never commit, never put EXPO_PUBLIC_ on these. Used by CLI /
# Edge Functions only. Keep in .env.local (gitignored), not here.
# ---------------------------------------------------------------------------
# SUPABASE_ACCESS_TOKEN=        # CLI auth (dashboard > account > tokens)
# SUPABASE_SERVICE_ROLE_KEY=    # server/Edge Functions only
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
