# Copy to .env and fill in values. Expo inlines EXPO_PUBLIC_* at build time.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# VPS CDN — public avatars + post-media (nginx: cdn.parul.pet/media/<bucket>/…)
EXPO_PUBLIC_CDN_URL=https://cdn.parul.pet

# VPS thumbnail webhook (POST with Authorization: Bearer <secret>)
EXPO_PUBLIC_THUMB_WEBHOOK_URL=https://YOUR_VPS_HOST/thumbs/generate
EXPO_PUBLIC_THUMB_WEBHOOK_SECRET=your_shared_secret
